{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@morphdsl/mcp",
	"version": "0.1.9",
	"description": "Morph mcp",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "apps/mcp",
		"type": "git",
		"url": "git+https://github.com/willclarktech/morph.git"
	},
	"type": "module",
	"files": [
		"dist"
	],
	"bin": {
		"morph-mcp": "./dist/cli.js"
	},
	"publishConfig": {
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"scripts": {
		"build": "bun build ./src/index.ts ./src/cli.ts --outdir dist --target node --format esm --packages external && tsc -p tsconfig.build.json",
		"build:check": "tsc --noEmit",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"inspect": "bunx @modelcontextprotocol/inspector bun src/index.ts",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"start": "bun src/index.ts",
		"test": "bun test",
		"test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage"
	},
	"dependencies": {
		"@morphdsl/generation-core": "workspace:*",
		"@morphdsl/runtime-mcp": "workspace:*",
		"@morphdsl/schema-dsl-core": "workspace:*",
		"effect": "^3.19.13"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "workspace:*",
		"@morphdsl/scenario-runner-mcp": "workspace:*",
		"@morphdsl/scenarios": "workspace:*",
		"@morphdsl/tsconfig": "workspace:*",
		"eslint": "^9.39.0",
		"prettier": "^3.4.2",
		"typescript": "^5.7.2"
	}
}
