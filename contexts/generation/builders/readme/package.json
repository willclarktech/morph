{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@morphdsl/builder-readme",
	"version": "0.0.0",
	"description": "Morph readme builder",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "contexts/generation/builders/readme",
		"type": "git",
		"url": "https://github.com/morphdsl/morph"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"build:check": "tsc --noEmit",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"test": "bun test",
		"test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage"
	},
	"dependencies": {
		"@morphdsl/domain-schema": "*",
		"@morphdsl/plugin": "*"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "*",
		"@morphdsl/tsconfig": "*",
		"eslint": "^9.39.0"
	}
}
