{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$defs": {
		"TypeRef": {
			"anyOf": [
				{
					"type": "object",
					"required": ["kind", "name"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["primitive"]
						},
						"name": {
							"type": "string",
							"enum": ["boolean", "number", "string", "unknown", "void"]
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "name"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["typeParam"]
						},
						"name": {
							"type": "string"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["entity", "kind"],
					"properties": {
						"context": {
							"type": "string"
						},
						"entity": {
							"type": "string"
						},
						"kind": {
							"type": "string",
							"enum": ["entityId"]
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "name"],
					"properties": {
						"context": {
							"type": "string"
						},
						"kind": {
							"type": "string",
							"enum": ["entity"]
						},
						"name": {
							"type": "string"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "name"],
					"properties": {
						"context": {
							"type": "string"
						},
						"kind": {
							"type": "string",
							"enum": ["type"]
						},
						"name": {
							"type": "string"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "values"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["union"]
						},
						"values": {
							"type": "array",
							"items": {
								"type": "string"
							}
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "name"],
					"properties": {
						"context": {
							"type": "string"
						},
						"kind": {
							"type": "string",
							"enum": ["valueObject"]
						},
						"name": {
							"type": "string"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["element", "kind"],
					"properties": {
						"element": {
							"$ref": "#/$defs/TypeRef"
						},
						"kind": {
							"type": "string",
							"enum": ["array"]
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["inner", "kind"],
					"properties": {
						"inner": {
							"$ref": "#/$defs/TypeRef"
						},
						"kind": {
							"type": "string",
							"enum": ["optional"]
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["args", "kind", "name"],
					"properties": {
						"args": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/TypeRef"
							}
						},
						"context": {
							"type": "string"
						},
						"kind": {
							"type": "string",
							"enum": ["generic"]
						},
						"name": {
							"type": "string"
						}
					},
					"additionalProperties": false
				}
			]
		},
		"ConditionExpr": {
			"anyOf": [
				{
					"type": "object",
					"required": ["kind", "left", "right"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["equals"]
						},
						"left": {
							"$ref": "#/$defs/ValueExpr"
						},
						"right": {
							"$ref": "#/$defs/ValueExpr"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "left", "right"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["notEquals"]
						},
						"left": {
							"$ref": "#/$defs/ValueExpr"
						},
						"right": {
							"$ref": "#/$defs/ValueExpr"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "left", "right"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["greaterThan"]
						},
						"left": {
							"$ref": "#/$defs/ValueExpr"
						},
						"right": {
							"$ref": "#/$defs/ValueExpr"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "left", "right"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["greaterThanOrEqual"]
						},
						"left": {
							"$ref": "#/$defs/ValueExpr"
						},
						"right": {
							"$ref": "#/$defs/ValueExpr"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "left", "right"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["lessThan"]
						},
						"left": {
							"$ref": "#/$defs/ValueExpr"
						},
						"right": {
							"$ref": "#/$defs/ValueExpr"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "left", "right"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["lessThanOrEqual"]
						},
						"left": {
							"$ref": "#/$defs/ValueExpr"
						},
						"right": {
							"$ref": "#/$defs/ValueExpr"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["collection", "kind", "value"],
					"properties": {
						"collection": {
							"$ref": "#/$defs/ValueExpr"
						},
						"kind": {
							"type": "string",
							"enum": ["contains"]
						},
						"value": {
							"$ref": "#/$defs/ValueExpr"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["condition", "kind"],
					"properties": {
						"condition": {
							"$ref": "#/$defs/ConditionExpr"
						},
						"kind": {
							"type": "string",
							"enum": ["not"]
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["conditions", "kind"],
					"properties": {
						"conditions": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/ConditionExpr"
							}
						},
						"kind": {
							"type": "string",
							"enum": ["and"]
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["conditions", "kind"],
					"properties": {
						"conditions": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/ConditionExpr"
							}
						},
						"kind": {
							"type": "string",
							"enum": ["or"]
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["if", "kind", "then"],
					"properties": {
						"if": {
							"$ref": "#/$defs/ConditionExpr"
						},
						"kind": {
							"type": "string",
							"enum": ["implies"]
						},
						"then": {
							"$ref": "#/$defs/ConditionExpr"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["collection", "condition", "kind", "variable"],
					"properties": {
						"collection": {
							"$ref": "#/$defs/ValueExpr"
						},
						"condition": {
							"$ref": "#/$defs/ConditionExpr"
						},
						"kind": {
							"type": "string",
							"enum": ["exists"]
						},
						"variable": {
							"type": "string"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["collection", "condition", "kind", "variable"],
					"properties": {
						"collection": {
							"$ref": "#/$defs/ValueExpr"
						},
						"condition": {
							"$ref": "#/$defs/ConditionExpr"
						},
						"kind": {
							"type": "string",
							"enum": ["forAll"]
						},
						"variable": {
							"type": "string"
						}
					},
					"additionalProperties": false
				}
			]
		},
		"ValueExpr": {
			"anyOf": [
				{
					"type": "object",
					"required": ["kind", "path"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["field"]
						},
						"path": {
							"type": "string"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "value"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["literal"]
						},
						"value": {
							"$id": "/schemas/unknown",
							"title": "unknown"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["kind", "name"],
					"properties": {
						"kind": {
							"type": "string",
							"enum": ["variable"]
						},
						"name": {
							"type": "string"
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["collection", "kind"],
					"properties": {
						"collection": {
							"$ref": "#/$defs/ValueExpr"
						},
						"kind": {
							"type": "string",
							"enum": ["count"]
						}
					},
					"additionalProperties": false
				}
			]
		}
	},
	"type": "object",
	"required": ["contexts", "name"],
	"properties": {
		"$schema": {
			"type": "string"
		},
		"contexts": {
			"type": "object",
			"required": [],
			"properties": {},
			"additionalProperties": {
				"type": "object",
				"required": ["description", "entities"],
				"properties": {
					"commands": {
						"type": "object",
						"required": [],
						"properties": {},
						"additionalProperties": {
							"type": "object",
							"required": ["description", "emits", "input", "output", "uses"],
							"properties": {
								"description": {
									"type": "string"
								},
								"emits": {
									"type": "array",
									"items": {
										"type": "object",
										"required": ["description", "name"],
										"properties": {
											"description": {
												"type": "string"
											},
											"name": {
												"type": "string"
											}
										},
										"additionalProperties": false
									},
									"description": "an array of at least 1 item(s)",
									"title": "minItems(1)",
									"minItems": 1
								},
								"errors": {
									"type": "array",
									"items": {
										"type": "object",
										"required": ["description", "name", "when"],
										"properties": {
											"description": {
												"type": "string"
											},
											"name": {
												"type": "string"
											},
											"when": {
												"type": "string"
											}
										},
										"additionalProperties": false
									}
								},
								"input": {
									"type": "object",
									"required": [],
									"properties": {},
									"additionalProperties": {
										"type": "object",
										"required": ["description", "type"],
										"properties": {
											"default": {
												"$id": "/schemas/unknown",
												"title": "unknown"
											},
											"description": {
												"type": "string"
											},
											"optional": {
												"type": "boolean"
											},
											"sensitive": {
												"type": "boolean"
											},
											"type": {
												"$ref": "#/$defs/TypeRef"
											}
										},
										"additionalProperties": false
									}
								},
								"output": {
									"$ref": "#/$defs/TypeRef"
								},
								"post": {
									"type": "array",
									"items": {
										"type": "string"
									}
								},
								"pre": {
									"type": "array",
									"items": {
										"type": "string"
									}
								},
								"tags": {
									"type": "array",
									"items": {
										"type": "string"
									}
								},
								"uses": {
									"type": "array",
									"items": {
										"type": "object",
										"required": ["access", "aggregate"],
										"properties": {
											"access": {
												"type": "string",
												"enum": ["read", "write"]
											},
											"aggregate": {
												"type": "string"
											}
										},
										"additionalProperties": false
									}
								}
							},
							"additionalProperties": false
						}
					},
					"dependencies": {
						"type": "array",
						"items": {
							"type": "string"
						}
					},
					"description": {
						"type": "string"
					},
					"entities": {
						"type": "object",
						"required": [],
						"properties": {},
