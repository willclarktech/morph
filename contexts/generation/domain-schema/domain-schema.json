							"type": "object",
							"required": ["attributes", "description"],
							"properties": {
								"aggregate": {
									"type": "object",
									"required": ["root"],
									"properties": {
										"cascadeDelete": {
											"type": "boolean"
										},
										"parent": {
											"type": "string"
										},
										"root": {
											"type": "boolean"
										}
									},
									"additionalProperties": false
								},
								"attributes": {
									"type": "object",
									"required": [],
									"properties": {},
									"additionalProperties": {
										"type": "object",
										"required": ["description", "type"],
										"properties": {
											"constraints": {
												"type": "array",
												"items": {
													"anyOf": [
														{
															"type": "object",
															"required": ["kind"],
															"properties": {
																"kind": {
																	"type": "string",
																	"enum": ["nonEmpty"]
																}
															},
															"additionalProperties": false
														},
														{
															"type": "object",
															"required": ["kind"],
															"properties": {
																"kind": {
																	"type": "string",
																	"enum": ["positive"]
																}
															},
															"additionalProperties": false
														},
														{
															"type": "object",
															"required": ["kind", "regex"],
															"properties": {
																"kind": {
																	"type": "string",
																	"enum": ["pattern"]
																},
																"regex": {
																	"type": "string"
																}
															},
															"additionalProperties": false
														},
														{
															"type": "object",
															"required": ["kind"],
															"properties": {
																"kind": {
																	"type": "string",
																	"enum": ["range"]
																},
																"max": {
																	"type": "number"
																},
																"min": {
																	"type": "number"
																}
															},
															"additionalProperties": false
														},
														{
															"type": "object",
															"required": ["description", "kind", "name"],
															"properties": {
																"description": {
																	"type": "string"
																},
																"kind": {
																	"type": "string",
																	"enum": ["custom"]
																},
																"name": {
																	"type": "string"
																}
															},
															"additionalProperties": false
														},
														{
															"type": "object",
															"required": ["kind"],
															"properties": {
																"kind": {
																	"type": "string",
																	"enum": ["unique"]
																}
															},
															"additionalProperties": false
														}
													]
												}
											},
											"description": {
												"type": "string"
											},
											"optional": {
												"type": "boolean"
											},
											"type": {
												"$ref": "#/$defs/TypeRef"
											}
										},
										"additionalProperties": false
									}
								},
								"description": {
									"type": "string"
								},
								"relationships": {
									"type": "array",
									"items": {
										"type": "object",
										"required": ["description", "kind", "target"],
										"properties": {
											"description": {
												"type": "string"
											},
											"inverse": {
												"type": "string"
											},
											"kind": {
												"type": "string",
												"enum": [
													"belongs_to",
													"has_many",
													"has_one",
													"references"
												]
											},
											"target": {
												"type": "string"
											}
										},
										"additionalProperties": false
									}
								}
							},
							"additionalProperties": false
						}
					},
					"errors": {
						"type": "object",
						"required": [],
						"properties": {},
						"additionalProperties": {
							"type": "object",
							"required": ["description", "fields"],
							"properties": {
								"description": {
									"type": "string"
								},
								"fields": {
									"type": "object",
									"required": [],
									"properties": {},
									"additionalProperties": {
										"type": "object",
										"required": ["type"],
										"properties": {
											"description": {
												"type": "string"
											},
											"optional": {
												"type": "boolean"
											},
											"type": {
												"$ref": "#/$defs/TypeRef"
											}
										},
										"additionalProperties": false
									}
								}
							},
							"additionalProperties": false
						}
					},
					"functions": {
						"type": "object",
						"required": [],
						"properties": {},
						"additionalProperties": {
							"type": "object",
							"required": ["description", "input", "output"],
							"properties": {
								"description": {
									"type": "string"
								},
								"errors": {
									"type": "array",
									"items": {
										"type": "object",
										"required": ["description", "name", "when"],
										"properties": {
											"description": {
												"type": "string"
											},
											"name": {
												"type": "string"
											},
											"when": {
												"type": "string"
											}
										},
										"additionalProperties": false
									}
								},
								"input": {
									"type": "object",
									"required": [],
									"properties": {},
									"additionalProperties": {
										"type": "object",
										"required": ["description", "type"],
										"properties": {
											"default": {
												"$id": "/schemas/unknown",
												"title": "unknown"
											},
											"description": {
												"type": "string"
											},
											"optional": {
												"type": "boolean"
											},
											"sensitive": {
												"type": "boolean"
											},
											"type": {
												"$ref": "#/$defs/TypeRef"
											}
										},
										"additionalProperties": false
									}
								},
								"output": {
									"$ref": "#/$defs/TypeRef"
								},
								"tags": {
									"type": "array",
									"items": {
										"type": "string"
									}
								},
								"typeParameters": {
									"type": "array",
									"items": {
										"type": "object",
										"required": ["name"],
										"properties": {
											"constraint": {
												"$ref": "#/$defs/TypeRef"
											},
											"default": {
												"$ref": "#/$defs/TypeRef"
											},
											"name": {
												"type": "string"
											}
										},
										"additionalProperties": false
									}
								}
							},
							"additionalProperties": false
						}
					},
					"invariants": {
						"type": "array",
