											"additionalProperties": false
										},
										{
											"type": "object",
											"required": ["entity", "kind"],
											"properties": {
												"entity": {
													"type": "string"
												},
												"kind": {
													"type": "string",
													"enum": ["entity"]
												}
											},
											"additionalProperties": false
