{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@morphdsl/domain-schema",
	"version": "0.0.0",
	"description": "Morph domain schema types and utilities",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "contexts/generation/domain-schema",
		"type": "git",
		"url": "https://github.com/morphdsl/morph"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"build:check": "tsc --noEmit",
		"build:json-schema": "bun scripts/generate-json-schema.ts",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"test": "bun test",
		"test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage"
	},
	"dependencies": {
		"@morphdsl/utils": "*",
		"effect": "^3.19.13"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "*",
		"@morphdsl/tsconfig": "*",
		"eslint": "^9.39.0"
	}
}
