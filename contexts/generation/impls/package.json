{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@morphdsl/generation-impls",
	"version": "0.1.3",
	"description": "Morph generation implementations",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "contexts/generation/impls",
		"type": "git",
		"url": "git+https://github.com/willclarktech/morph.git"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir dist --target node --format esm --packages external && tsc -p tsconfig.build.json",
		"build:check": "tsc --noEmit",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"dependencies": {
		"@morphdsl/builder-app": "workspace:*",
		"@morphdsl/builder-scaffold": "workspace:*",
		"@morphdsl/domain-schema": "workspace:*",
		"@morphdsl/generation-dsl": "workspace:*",
		"@morphdsl/generator-env": "workspace:*",
		"@morphdsl/plugin": "workspace:*",
		"@morphdsl/plugin-api": "workspace:*",
		"@morphdsl/plugin-cli": "workspace:*",
		"@morphdsl/plugin-cli-client": "workspace:*",
		"@morphdsl/plugin-client": "workspace:*",
		"@morphdsl/plugin-core": "workspace:*",
		"@morphdsl/plugin-dsl": "workspace:*",
		"@morphdsl/plugin-mcp": "workspace:*",
		"@morphdsl/plugin-monorepo-root": "workspace:*",
		"@morphdsl/plugin-proto": "workspace:*",
		"@morphdsl/plugin-ui": "workspace:*",
		"@morphdsl/plugin-verification": "workspace:*",
		"@morphdsl/plugin-vscode": "workspace:*",
		"@morphdsl/runtime-ui": "workspace:*",
		"@morphdsl/schema-dsl-compiler": "workspace:*",
		"@morphdsl/schema-dsl-parser": "workspace:*",
		"effect": "^3.19.13"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "workspace:*",
		"@morphdsl/tsconfig": "workspace:*",
		"eslint": "^9.39.0",
		"prettier": "^3.4.2",
		"typescript": "^5.7.2"
	}
}
