{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@morphdsl/plugin",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build:check": "tsc --noEmit",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "bun test",
		"test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage"
	},
	"dependencies": {
		"@morphdsl/builder-app": "workspace:*",
		"@morphdsl/domain-schema": "workspace:*"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "workspace:*",
		"@morphdsl/tsconfig": "workspace:*",
		"eslint": "^9.39.0",
		"prettier": "^3.4.2",
		"typescript": "^5.7.2"
	}
}
