{
	"name": "@morphdsl/scenario-runner-cli-client",
	"version": "0.1.9",
	"description": "Morph cli-client scenario runner",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "contexts/generation/targets/cli-client/scenario-runner",
		"type": "git",
		"url": "git+https://github.com/willclarktech/morph.git"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"README.md",
		"dist"
	],
	"publishConfig": {
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir dist --target node --format esm --packages external && tsc -p tsconfig.build.json",
		"build:check": "tsc --noEmit",
		"lint": "eslint . --report-unused-disable-directives",
		"lint:fix": "eslint . --fix --report-unused-disable-directives"
	},
	"dependencies": {
		"@morphdsl/scenario-runner": "workspace:*",
		"@morphdsl/scenario-runner-api": "workspace:*"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "workspace:*",
		"@types/node": "^22.15.3",
		"typescript": "^5.8.3"
	}
}
