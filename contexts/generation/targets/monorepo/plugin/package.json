{
	"name": "@morphdsl/plugin-monorepo-root",
	"version": "0.1.1",
	"description": "Morph monorepo-root plugin",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "contexts/generation/targets/monorepo/plugin",
		"type": "git",
		"url": "git+https://github.com/willclarktech/morph.git"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir dist --target node --format esm --packages external && tsc -p tsconfig.build.json",
		"build:check": "tsc --noEmit"
	},
	"dependencies": {
		"@morphdsl/builder-app": "*",
		"@morphdsl/builder-readme": "*",
		"@morphdsl/domain-schema": "*",
		"@morphdsl/generator-diagrams": "*",
		"@morphdsl/generator-license": "*",
		"@morphdsl/plugin": "*"
	},
	"devDependencies": {
		"typescript": "^5.8.3"
	}
}
