{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@morphdsl/generator-vscode",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"build:check": "tsc --noEmit",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint --fix ."
	},
	"dependencies": {
		"@morphdsl/builder-app": "*",
		"@morphdsl/domain-schema": "*",
		"@morphdsl/operation": "workspace:*",
		"@morphdsl/utils": "*",
		"effect": "^3.16.0"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "*",
		"@morphdsl/tsconfig": "*",
		"@types/vscode": "^1.96.0",
		"eslint": "^9.39.0"
	}
}
