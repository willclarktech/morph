{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@morphdsl/generator-vscode",
	"version": "0.1.1",
	"description": "Morph vscode generator",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "contexts/generation/targets/vscode/generator",
		"type": "git",
		"url": "git+https://github.com/willclarktech/morph.git"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.ts"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir dist --target node --format esm --packages external && tsc -p tsconfig.build.json",
		"build:check": "tsc --noEmit",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint --fix ."
	},
	"dependencies": {
		"@morphdsl/builder-app": "*",
		"@morphdsl/domain-schema": "*",
		"@morphdsl/operation": "workspace:*",
		"@morphdsl/utils": "*",
		"effect": "^3.16.0"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "*",
		"@morphdsl/tsconfig": "*",
		"@types/vscode": "^1.96.0",
		"eslint": "^9.39.0"
	}
}
