{
	"name": "@morphdsl/scenario-runner",
	"version": "0.1.8",
	"description": "Morph scenario-runner",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "contexts/generation/testing/scenario-runner",
		"type": "git",
		"url": "git+https://github.com/willclarktech/morph.git"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir dist --target node --format esm --packages external && tsc -p tsconfig.build.json",
		"build:check": "tsc --noEmit",
		"lint": "eslint . --report-unused-disable-directives",
		"lint:fix": "eslint . --fix --report-unused-disable-directives",
		"test": "bun test",
		"test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage"
	},
	"dependencies": {
		"@morphdsl/scenario": "workspace:*",
		"effect": "^3.19.13"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "workspace:*",
		"typescript": "^5.8.3"
	}
}
