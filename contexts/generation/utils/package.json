{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@morphdsl/utils",
	"version": "0.0.0",
	"description": "Morph shared utilities",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "contexts/generation/utils",
		"type": "git",
		"url": "https://github.com/morphdsl/morph"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build:check": "tsc --noEmit",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "bun test",
		"test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "workspace:*",
		"@morphdsl/tsconfig": "workspace:*",
		"eslint": "^9.39.0",
		"fast-check": "^3.23.1",
		"prettier": "^3.4.2",
		"typescript": "^5.7.2"
	}
}
