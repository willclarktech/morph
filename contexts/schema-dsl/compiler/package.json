{
	"name": "@morphdsl/schema-dsl-compiler",
	"version": "0.0.0",
	"description": "Morph schema DSL compiler",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "contexts/schema-dsl/compiler",
		"type": "git",
		"url": "git+https://github.com/willclarktech/morph.git"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"files": ["dist"],
	"publishConfig": {
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			}
		}
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir dist --target node --format esm --packages external && tsc -p tsconfig.build.json",
		"build:check": "tsc --noEmit",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint --fix ."
	},
	"dependencies": {
		"@morphdsl/domain-schema": "workspace:*",
		"@morphdsl/schema-dsl-parser": "workspace:*"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "workspace:*",
		"@morphdsl/tsconfig": "workspace:*",
		"@types/bun": "latest",
		"eslint": "^9.0.0",
		"prettier": "^3.0.0",
		"typescript": "^5.0.0"
	}
}
