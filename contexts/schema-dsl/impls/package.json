{
	"$schema": "https://json-schema.org/package.json",
	"name": "@morphdsl/schema-dsl-impls",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"dependencies": {
		"@morphdsl/domain-schema": "workspace:*",
		"@morphdsl/schema-dsl-dsl": "workspace:*",
		"@morphdsl/schema-dsl-parser": "workspace:*",
		"@morphdsl/schema-dsl-compiler": "workspace:*",
		"@morphdsl/schema-dsl-decompiler": "workspace:*",
		"effect": "^3.19.13"
	},
	"devDependencies": {
		"@morphdsl/eslint-config": "workspace:*",
		"@morphdsl/tsconfig": "workspace:*",
		"eslint": "^9.39.0",
		"prettier": "^3.4.2",
		"typescript": "^5.7.2"
	},
	"scripts": {
		"build:check": "tsc --noEmit",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "bun test",
		"test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage"
	}
}
