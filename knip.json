{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"ignore": [
		"examples/**",
		"template/**",
		"**/impl.template.ts",
		"**/mocks/deps.ts",
		"**/mocks/handlers.ts",
		"**/viz/**",
		"**/eslint.config.ts"
	],
	"ignoreDependencies": [
		"@morphdsl/tsconfig",
		"@morphdsl/eslint-config",
		"@morphdsl/generation-dsl",
		"@morphdsl/schema-dsl-dsl",
		"@morphdsl/testing",
		"@morphdsl/codec-json-impls",
		"@morphdsl/codec-yaml-impls",
		"@types/vscode",
		"effect"
	],
	"ignoreExportsUsedInFile": true,
	"workspaces": {
		"apps/vscode": {
			"entry": ["src/extension.ts"]
		}
	}
}
