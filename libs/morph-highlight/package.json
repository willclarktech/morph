	"private": true,
	"description": "Morph DSL syntax highlighting — shared vocabulary, tokenizer, and HTML renderer",
	"license": "MIT",
	"author": "Morph Contributors",
	"repository": {
		"directory": "libs/morph-highlight",
		"type": "git",
