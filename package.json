{
	"name": "morph",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.5",
	"workspaces": [
		"config/*",
		"contexts/generation/dsl",
		"contexts/generation/core",
		"contexts/generation/impls",
		"contexts/generation/utils",
		"contexts/generation/plugin",
		"contexts/generation/domain-schema",
		"contexts/generation/operation",
		"contexts/generation/http-client",
		"contexts/generation/builders/*",
		"contexts/generation/generators/*",
		"contexts/generation/testing/*",
		"contexts/generation/targets/*/generator",
		"contexts/generation/targets/*/plugin",
		"contexts/generation/targets/*/scenario-runner",
		"contexts/generation/targets/*/property-runner",
		"extensions/*/dsl",
		"extensions/*/impls",
		"examples/*/config/*",
		"examples/*/contexts/*/dsl",
		"examples/*/contexts/*/core",
		"examples/*/libs/*",
		"examples/*/apps/*",
		"examples/*/tests/*",
		"contexts/schema-dsl/dsl",
		"contexts/schema-dsl/core",
		"contexts/schema-dsl/impls",
		"contexts/schema-dsl/parser",
		"contexts/schema-dsl/compiler",
		"contexts/schema-dsl/decompiler",
		"apps/*",
		"libs/*",
		"tests/*"
	],
	"scripts": {
		"build:check": "tsc --noEmit && turbo run build:check --concurrency=25%",
		"format": "turbo run format //#format:root --concurrency=25%",
		"format:fix": "turbo run format:fix //#format:root:fix --concurrency=25%",
		"format:root": "prettier --check scripts",
		"format:root:fix": "prettier --write scripts",
		"generate:examples": "bun scripts/generate-examples.ts",
		"regenerate:morph": "bun scripts/regenerate-morph.ts",
		"lint": "turbo run lint //#lint:root --concurrency=25%",
		"lint:fix": "turbo run lint:fix //#lint:root:fix --concurrency=25%",
		"lint:root": "eslint scripts",
		"lint:root:fix": "eslint --fix scripts",
		"test": "turbo run test --concurrency=25%",
		"test:coverage": "turbo run test:coverage --concurrency=25%",
		"coverage:report": "bun scripts/coverage-report.ts",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "changeset publish",
		"worktree:list": "bun scripts/worktree.ts list",
		"worktree:new": "bun scripts/worktree.ts new",
		"worktree:remove": "bun scripts/worktree.ts remove"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.29.8",
		"@morphdsl/eslint-config": "workspace:*",
		"@types/bun": "latest",
		"effect": "^3.19.13",
		"eslint": "^9.39.2",
		"knip": "^5.81.0",
		"prettier": "^3.8.0",
		"turbo": "^2.7.5",
		"typescript": "^5.9.3"
	}
}
