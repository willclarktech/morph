					],
					"input": {
						"name": {
							"description": "Project name for package naming",
							"type": {
								"kind": "primitive",
								"name": "string"
							}
						},
						"schema": {
							"description": "The domain schema as .morph DSL or JSON text",
							"type": {
								"kind": "primitive",
								"name": "string"
							}
						}
					},
					"output": {
						"kind": "type",
						"name": "GenerationResult"
